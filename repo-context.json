{
  "project": {
    "name": "ecosistema-webs-nextjs",
    "description": "Sistema multi-brand en Next.js donde cada build representa una marca independiente",
    "framework": "Next.js 16 App Router",
    "language": "TypeScript strict",
    "styling": "Tailwind CSS v4 + CSS variables por marca",
    "deployment_model": "1 dominio = 1 marca activa por build",
    "active_brand_env": "NEXT_PUBLIC_BRAND_SLUG",
    "site_url_env": "NEXT_PUBLIC_SITE_URL"
  },

  "architecture": {
    "layers": [
      {
        "name": "app",
        "path": "src/app",
        "responsibility": "routing, pages, metadata, sitemap, robots",
        "can_import_from": [
          "components/brand",
          "components/shared",
          "lib/core",
          "lib/brands",
          "lib/types"
        ]
      },
      {
        "name": "components/brand",
        "path": "src/components/brand",
        "responsibility": "renderizado de secciones por marca",
        "can_import_from": ["components/shared", "lib/core", "lib/types"]
      },
      {
        "name": "components/shared",
        "path": "src/components/shared",
        "responsibility": "componentes reutilizables agnósticos",
        "can_import_from": ["lib/core", "lib/types"]
      },
      {
        "name": "lib/core",
        "path": "src/lib/core",
        "responsibility": "resolución de marca, metadata, theme vars",
        "can_import_from": ["lib/brands", "lib/types"]
      },
      {
        "name": "lib/brands",
        "path": "src/lib/brands",
        "responsibility": "configuración pura de cada marca",
        "can_import_from": ["lib/types"]
      },
      {
        "name": "lib/types",
        "path": "src/lib/types",
        "responsibility": "tipos globales",
        "can_import_from": []
      }
    ],

    "rules": [
      "shared puede usar core pero nunca brands directamente",
      "brands no pueden importar core",
      "no lógica de marca fuera de lib/brands",
      "no rutas dinámicas por marca"
    ]
  },

  "routing": {
    "home": "src/app/page.tsx",
    "thank_you": "src/app/gracias/page.tsx",
    "layout": "src/app/layout.tsx",
    "rule": "la marca activa se resuelve en build mediante env"
  },

  "brand_system": {
    "brand_keys": ["aelor", "dextor", "ixera", "nixen", "raxor", "vaxen"],
    "brand_registry_file": "src/lib/brands/registry.ts",
    "brand_type_file": "src/lib/types/brand.ts",
    "pattern": "src/lib/brands/<brand>/index.ts",

    "structure_layers": ["content", "links", "assets", "theme", "ui"]
  },

  "tooling": {
    "scripts": {
      "dev": "next dev -p 3001",
      "build": "next build",
      "lint": "eslint .",
      "typecheck": "tsc --noEmit",
      "format": "prettier . --write",
      "check": "npm run lint && npm run typecheck && npm run build"
    },

    "quality_pipeline": {
      "pre_commit": "lint-staged (eslint + prettier)",
      "pre_push": "npm run check",
      "ci": "GitHub Actions ejecuta npm run check"
    },

    "stack": {
      "typescript_strict": true,
      "eslint_architecture_enforced": true,
      "prettier": true,
      "husky": true,
      "lint_staged": true
    }
  },

  "env": {
    "required": ["NEXT_PUBLIC_BRAND_SLUG"],
    "optional": ["NEXT_PUBLIC_SITE_URL"],
    "constraint": "si el slug es inválido → build falla"
  },

  "critical_files": [
    "src/lib/types/brand.ts",
    "src/lib/types/theme.ts",
    "src/lib/brands/registry.ts",
    "src/lib/core/active-brand.ts",
    "src/lib/core/theme-vars.ts",
    "eslint.config.mjs"
  ],

  "agent_rules": {
    "must_read_repo_context": true,
    "must_run_check": true,

    "forbidden": [
      "if (brand.slug === ...) en shared",
      "hardcode de colores fuera de brands",
      "modificar arquitectura sin justificación",
      "usar any"
    ],

    "safe": [
      "editar contenido de marca",
      "ajustar variantes UI",
      "refactor interno sin cambiar contratos"
    ],

    "high_risk": [
      "modificar tipos globales",
      "modificar theme system",
      "cambiar resolución de marca",
      "romper imports entre capas"
    ]
  },

  "prompt_usage": {
    "goal": "usar este JSON para generar prompts seguros para Claude Code",
    "output_format": ["diagnóstico", "riesgos", "prompt listo", "orden de ejecución"]
  }
}
