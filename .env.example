# =====================================================
# ECOSISTEMA — ENVIRONMENT VARIABLES
# =====================================================

# REQUIRED
# Defines the active brand for this deployment.
# Must match one of the keys in src/lib/brands/
# If missing or invalid → build will fail
# Valid values: aelor, dextor, ixera, nixen, raxor, vaxen
NEXT_PUBLIC_BRAND_SLUG=nixen

# OPTIONAL
# Base URL for this deployment (used for SEO, metadata, sitemap)
# Defaults to http://localhost:3001 if not provided
# Example (production): https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3001
